{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(bun:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(tmux:*)",
      "Bash(clone-workspace:*)",
      "Bash(switch-workspace:*)",
      "Bash(tmux-sessionizer:*)",
      "Bash(stow:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git push\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\n# Show what's about to be pushed — no blocking, safe for automation\nbranch=$(git branch --show-current 2>/dev/null || echo 'unknown')\ncount=$(git log origin/$branch..HEAD --oneline 2>/dev/null | wc -l | tr -d ' ')\nif [ \"$count\" -gt 0 ]; then\n  echo \"[Hook] Pushing $count commit(s) on $branch:\" >&2\n  git log origin/$branch..HEAD --oneline 2>/dev/null >&2\nfi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"gh pr create\"",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\npr_url=$(echo \"$input\" | jq -r '.tool_output.output // \"\"' | grep -oE 'https://github.com/[^/]+/[^/]+/pull/[0-9]+' || true)\nif [ -n \"$pr_url\" ]; then\n  pr_num=$(echo \"$pr_url\" | sed -E 's|.*/pull/([0-9]+)|\\1|')\n  echo \"[Hook] PR created: $pr_url\" >&2\n  echo \"[Hook] Review: gh pr review $pr_num\" >&2\nfi\necho \"$input\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nerap/.claude/scripts/notify-tmux.sh permission"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nerap/.claude/scripts/notify-tmux.sh idle"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/nerap/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "posthog@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
