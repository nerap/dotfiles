#!/usr/bin/env bash
# devbox — drive the EC2 dev box from your laptop.
#
#   devbox up         start it, refresh SSH config, attach tmux   (the everyday one)
#   devbox down       stop it now (billing pauses; disks persist)
#   devbox status     state / type / ip / cost-so-far-today
#   devbox ssh        shell on the box (no tmux attach)
#   devbox attach     attach the remote tmux
#   devbox provision  (re)install tooling + dotfiles over SSH, agent-forwarded
#   devbox forwards   rewrite ~/.ssh/devbox.conf with the dev-port tunnels
#
# Config (override via env or ~/.config/devbox.env):
#   DEVBOX_PROFILE=admin   DEVBOX_REGION=eu-west-3   DEVBOX_NAME=devbox
set -uo pipefail

[ -f "$HOME/.config/devbox.env" ] && . "$HOME/.config/devbox.env"
PROFILE="${DEVBOX_PROFILE:-admin}"
REGION="${DEVBOX_REGION:-eu-west-3}"
NAME="${DEVBOX_NAME:-devbox}"
USER_REMOTE="${DEVBOX_USER:-ubuntu}"
SSH_CONF="$HOME/.ssh/devbox.conf"

aws_() { aws --profile "$PROFILE" --region "$REGION" "$@"; }
die() { printf '\033[31m✗ %s\033[0m\n' "$*" >&2; exit 1; }
say() { printf '\033[1;36m▸ %s\033[0m\n' "$*"; }

instance_id() {
  aws_ ec2 describe-instances \
    --filters "Name=tag:Name,Values=$NAME" "Name=instance-state-name,Values=pending,running,stopping,stopped" \
    --query 'Reservations[0].Instances[0].InstanceId' --output text 2>/dev/null
}
state()  { aws_ ec2 describe-instances --instance-ids "$1" --query 'Reservations[0].Instances[0].State.Name' --output text 2>/dev/null; }
pub_ip() { aws_ ec2 describe-instances --instance-ids "$1" --query 'Reservations[0].Instances[0].PublicIpAddress' --output text 2>/dev/null; }

need_id() {
  local id; id=$(instance_id)
  [ -n "$id" ] && [ "$id" != "None" ] || die "No instance tagged Name=$NAME in $REGION (profile $PROFILE). Run terraform apply first."
  echo "$id"
}

# Generate the SSH tunnels. Each worktree n exposes: vite 8080+n, and the supabase
# stack at 54321+(n-1)*100 .. +6. Forwarding them means localhost:8081 in your local
# browser still hits worktree 1 — exactly like it does today.
write_ssh_conf() {
  local ip="$1" f="$SSH_CONF"
  {
    echo "# GENERATED by \`devbox forwards\` — do not edit. IP changes on every start."
    echo "Host $NAME"
    echo "  HostName $ip"
    echo "  User $USER_REMOTE"
    echo "  ForwardAgent yes"
    echo "  ServerAliveInterval 30"
    echo "  ServerAliveCountMax 4"
    echo "  ControlMaster auto"
    echo "  ControlPath ~/.ssh/cm-%r@%h:%p"
    echo "  ControlPersist 10m"
    echo "  StrictHostKeyChecking accept-new"
    for n in 1 2 3 4 5 6 7 8; do
      echo "  LocalForward $((8080 + n)) 127.0.0.1:$((8080 + n))   # wt$n vite"
      local base=$((54321 + (n - 1) * 100))
      for o in 0 1 2 3 4 5 6; do
        echo "  LocalForward $((base + o)) 127.0.0.1:$((base + o))"
      done
    done
  } > "$f"
  chmod 600 "$f"

  # ssh only reads devbox.conf if the main config includes it (must be near the top:
  # ssh takes the FIRST value for each option).
  local main="$HOME/.ssh/config"
  touch "$main"; chmod 600 "$main"
  if ! grep -q '^Include devbox.conf' "$main"; then
    cp "$main" "$main.bak.$(date +%s)"
    printf 'Include devbox.conf\n\n%s' "$(cat "$main")" > "$main.tmp" && mv "$main.tmp" "$main"
    say "added 'Include devbox.conf' to ~/.ssh/config (backup saved)"
  fi
}

cmd_forwards() {
  local id ip; id=$(need_id); ip=$(pub_ip "$id")
  [ -n "$ip" ] && [ "$ip" != "None" ] || die "instance has no public IP (is it running?)"
  write_ssh_conf "$ip"
  say "ssh config -> $SSH_CONF (host: $NAME, ip: $ip, 64 tunnels)"
}

cmd_up() {
  local id st ip; id=$(need_id); st=$(state "$id")
  if [ "$st" != "running" ]; then
    say "starting $id ($st -> running)"
    aws_ ec2 start-instances --instance-ids "$id" >/dev/null || die "start failed"
    aws_ ec2 wait instance-running --instance-ids "$id" || die "never reached running"
  fi
  ip=$(pub_ip "$id")
  write_ssh_conf "$ip"
  say "waiting for sshd on $ip"
  for _ in $(seq 1 60); do
    ssh -o ConnectTimeout=3 -o BatchMode=yes "$NAME" true 2>/dev/null && break
    sleep 3
  done
  say "attaching (Ctrl+u for the fleet dashboard)"
  exec ssh -At "$NAME" 'tmux attach || tmux new -s main'
}

cmd_down() {
  local id; id=$(need_id)
  say "stopping $id — disks persist, billing for compute stops"
  aws_ ec2 stop-instances --instance-ids "$id" >/dev/null || die "stop failed"
  aws_ ec2 wait instance-stopped --instance-ids "$id" && say "stopped"
}

cmd_status() {
  local id; id=$(need_id)
  aws_ ec2 describe-instances --instance-ids "$id" \
    --query 'Reservations[0].Instances[0].{State:State.Name,Type:InstanceType,IP:PublicIpAddress,Since:LaunchTime}' \
    --output table
  if [ "$(state "$id")" = "running" ]; then
    ssh -o ConnectTimeout=4 -o BatchMode=yes "$NAME" \
      'echo; uptime; echo; tmux list-sessions 2>/dev/null | head -20; echo; ls -1 ~/.devbox-nostop 2>/dev/null && echo "(auto-stop DISABLED)"' 2>/dev/null
  fi
}

cmd_ssh()    { local id; id=$(need_id); [ "$(state "$id")" = running ] || die "not running — devbox up"; exec ssh -A "$NAME"; }
cmd_attach() { local id; id=$(need_id); [ "$(state "$id")" = running ] || die "not running — devbox up"; exec ssh -At "$NAME" 'tmux attach || tmux new -s main'; }

cmd_provision() {
  local id; id=$(need_id)
  [ "$(state "$id")" = running ] || die "not running — devbox up"
  ssh-add -l >/dev/null 2>&1 || die "no SSH agent — the box needs your forwarded key to clone private repos"
  cmd_forwards
  say "provisioning (agent-forwarded, so no credentials land on the box)"
  scp "$HOME/personal/dotfiles/infra/ec2-devbox/bootstrap.sh" "$NAME:/tmp/bootstrap.sh" || die "scp failed"
  exec ssh -At "$NAME" "IDLE_MINUTES=${DEVBOX_IDLE_MINUTES:-30} bash /tmp/bootstrap.sh"
}

case "${1:-}" in
  up)        cmd_up ;;
  down|stop) cmd_down ;;
  status)    cmd_status ;;
  ssh)       cmd_ssh ;;
  attach)    cmd_attach ;;
  provision) cmd_provision ;;
  forwards)  cmd_forwards ;;
  *) sed -n '2,20p' "$0" | sed 's/^# \?//'; exit 1 ;;
esac
