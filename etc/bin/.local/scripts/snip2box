#!/usr/bin/env bash
# snip2box — interactive screenshot -> ship to the devbox -> path on the clipboard.
# Bound to a hotkey (aerospace ctrl-cmd-p). Because aerospace runs this with a
# bare environment, everything is made explicit: absolute tool paths, a fixed
# HOME, a log file, and audible/visual feedback (notifications are unreliable
# when spawned from aerospace).
#
# Flow: hotkey -> drag a region (Esc cancels) -> PNG lands in ~ubuntu/Downloads
# on the box, its path is copied to the Mac clipboard, and a sound plays.
# Then Cmd+V the path into Claude on the box.
#
# Usage: snip2box [ssh-host]   (default: devbox).  Debug: tail -f ~/snip2box.log
set -uo pipefail
export HOME="/Users/nerap"
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$HOME/bin/.local/scripts"

HOST="${1:-devbox}"
LOG="$HOME/snip2box.log"
tmp="/tmp/snip-$(date +%s).png"

log()  { echo "$(date '+%H:%M:%S') $*" >> "$LOG"; }
ok()   { afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 & osascript -e "display notification \"$1\" with title \"snip2box\"" >/dev/null 2>&1; }
fail() { afplay /System/Library/Sounds/Basso.aiff >/dev/null 2>&1 & osascript -e "display notification \"$1\" with title \"snip2box FAILED\"" >/dev/null 2>&1; log "FAIL: $1"; }

log "=== run: host=$HOST ==="

# 1. interactive region capture; Esc / cancel leaves no file
/usr/sbin/screencapture -i "$tmp" 2>>"$LOG"
if [ ! -s "$tmp" ]; then log "cancelled or empty capture"; exit 0; fi
log "captured $(/usr/bin/stat -f%z "$tmp") bytes -> $tmp"

# 2. ship to the box (explicit ssh opts: no multiplexing, use ~/.ssh/config)
name=$(/usr/bin/basename "$tmp"); remote="Downloads/$name"; full="/home/ubuntu/$remote"
SSH_OPTS="-F $HOME/.ssh/config -o ControlMaster=no -o ControlPath=none -o ConnectTimeout=15 -o BatchMode=yes -o LogLevel=ERROR"
if /usr/bin/scp $SSH_OPTS -q "$tmp" "$HOST:$remote" 2>>"$LOG"; then
  log "scp OK -> $HOST:$remote"
else
  # retry once after ensuring the dir exists
  /usr/bin/ssh $SSH_OPTS "$HOST" 'mkdir -p ~/Downloads' 2>>"$LOG"
  if ! /usr/bin/scp $SSH_OPTS -q "$tmp" "$HOST:$remote" 2>>"$LOG"; then
    fail "scp to $HOST failed (box up? key?)"; /bin/rm -f "$tmp"; exit 1
  fi
fi
/bin/rm -f "$tmp"

# 3. path -> clipboard + feedback
printf '%s' "$full" | /usr/bin/pbcopy
log "clipboard set -> $full"
ok "Cmd+V into Claude"
printf '%s\n' "$full"
