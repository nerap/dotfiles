#!/usr/bin/env bash
# snip2box — ship the CLIPBOARD image to the devbox and put its path back on the
# clipboard. Reads the pasteboard with pngpaste (needs NO Screen Recording
# permission, unlike screencapture — which AeroSpace can't reliably get).
#
# Flow:
#   1. Screenshot to clipboard:  Cmd+Ctrl+Shift+4  (native macOS; the OS captures)
#   2. Press the hotkey (aerospace ctrl-cmd-p) -> this ships it + copies the path
#   3. Cmd+V the path into Claude on the box
#
# Usage: snip2box [ssh-host]   (default devbox).  Debug: cat ~/snip2box.log
set -uo pipefail
export HOME="/Users/nerap"
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$HOME/bin/.local/scripts"

HOST="${1:-devbox}"
LOG="$HOME/snip2box.log"
tmp="/tmp/snip-$(date +%s).png"

log()  { echo "$(date '+%H:%M:%S') $*" >> "$LOG"; }
ok()   { afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 & osascript -e "display notification \"$1\" with title \"snip2box\"" >/dev/null 2>&1; }
fail() { afplay /System/Library/Sounds/Basso.aiff >/dev/null 2>&1 & osascript -e "display notification \"$1\" with title \"snip2box\"" >/dev/null 2>&1; log "FAIL: $1"; }

log "=== run: host=$HOST ==="

# 1. pull the image OUT of the clipboard (no screen-recording perm needed)
if ! /opt/homebrew/bin/pngpaste "$tmp" 2>>"$LOG" || [ ! -s "$tmp" ]; then
  fail "no image in clipboard — screenshot first (Cmd+Ctrl+Shift+4)"
  /bin/rm -f "$tmp"; exit 1
fi
log "clipboard image: $(/usr/bin/stat -f%z "$tmp") bytes"

# 2. ship to the box
name=$(/usr/bin/basename "$tmp"); remote="Downloads/$name"; full="/home/ubuntu/$remote"
SSH_OPTS="-F $HOME/.ssh/config -o ControlMaster=no -o ControlPath=none -o ConnectTimeout=15 -o BatchMode=yes -o LogLevel=ERROR"
if ! /usr/bin/scp $SSH_OPTS -q "$tmp" "$HOST:$remote" 2>>"$LOG"; then
  /usr/bin/ssh $SSH_OPTS "$HOST" 'mkdir -p ~/Downloads' 2>>"$LOG"
  /usr/bin/scp $SSH_OPTS -q "$tmp" "$HOST:$remote" 2>>"$LOG" \
    || { fail "scp to $HOST failed (box up?)"; /bin/rm -f "$tmp"; exit 1; }
fi
/bin/rm -f "$tmp"
log "scp OK -> $full"

# 3. replace the clipboard with the box path, so Cmd+V pastes text
printf '%s' "$full" | /usr/bin/pbcopy
log "clipboard -> $full"
ok "path copied — Cmd+V into Claude"
printf '%s\n' "$full"
